rules_version = '2';

// Firestore security rules for anonymous chart notes + comments + announcement.
// Paste into: Firebase console → Firestore Database → Rules → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "XnMi4PnWRIV722yxz3khH7uFHOx1";
    }

    function validText() {
      return request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
    }

    function isServerCreate() {
      return request.resource.data.createdAt is timestamp
        && request.resource.data.createdAt == request.time;
    }

    match /notes/{noteId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "runId", "specId", "context", "step", "uid", "text", "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && validText()
        && request.resource.data.runId is string
        && request.resource.data.runId.size() > 0
        && request.resource.data.runId.size() <= 200
        && request.resource.data.specId is string
        && request.resource.data.specId.size() <= 500
        && request.resource.data.context in ["spec", "loss"]
        && (request.resource.data.step == null
          || (request.resource.data.step is int
            && request.resource.data.step >= 0
            && request.resource.data.step <= 1000000000000))
        && isServerCreate();

      allow update, delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;

        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly([
            "noteId", "uid", "text", "parentId", "createdAt"
          ])
          && request.resource.data.uid == request.auth.uid
          && validText()
          && request.resource.data.noteId == noteId
          && (request.resource.data.parentId == null
            || (request.resource.data.parentId is string
              && request.resource.data.parentId.size() <= 200
              && request.resource.data.parentId != commentId))
          && isServerCreate();

        allow update, delete: if isAdmin();
      }
    }

    match /handles/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site improvement suggestions — public read/create; curator-only replies/delete.
    match /suggestions/{suggestionId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "text", "uid", "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && validText()
        && isServerCreate();

      allow update: if false;
      allow delete: if isAdmin();

      match /replies/{replyId} {
        allow read: if true;

        allow create: if isAdmin()
          && request.resource.data.keys().hasOnly([
            "text", "uid", "createdAt"
          ])
          && request.resource.data.uid == request.auth.uid
          && validText()
          && isServerCreate();

        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // Multi announcements — anyone can read; only curator can write.
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "text", "uid", "createdAt", "updatedAt"
        ])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["text", "updatedAt"])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // Legacy single announcement doc (kept for migration).
    match /meta/siteAnnouncement {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin();
    }

    // Site-wide maintenance flag — public read; curator write.
    match /meta/siteMaintenance {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.enabled is bool;
      allow delete: if isAdmin();
    }

    match /meta/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
