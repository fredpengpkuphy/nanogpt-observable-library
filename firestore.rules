rules_version = '2';

// Firestore security rules for the anonymous chart-notes system.
//
// Paste these into: Firebase console → Firestore Database → Rules → Publish.
// Replace ADMIN_UID_HERE with your admin account's UID (Authentication → Users).

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "XnMi4PnWRIV722yxz3khH7uFHOx1";
    }

    // Notes: world-readable, any signed-in user may create their own,
    // only the curator may edit or delete.
    match /notes/{noteId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.handle is string
        && request.resource.data.step is number
        && request.resource.data.runId is string;

      allow update, delete: if isAdmin();
    }

    // Handles: publicly readable (so notes can display them). Each browser may
    // create only its own handle doc; the curator can clean up if needed.
    match /handles/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // Counter that allocates the next explorer_### number. Any signed-in user
    // may advance it (guarded by a transaction client-side). Low stakes: the
    // worst case is a skipped number.
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
