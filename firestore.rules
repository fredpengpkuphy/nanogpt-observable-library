rules_version = '2';

// Firestore security rules for anonymous chart notes + comments.
// Paste into: Firebase console → Firestore Database → Rules → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "XnMi4PnWRIV722yxz3khH7uFHOx1";
    }

    function validText() {
      return request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
    }

    match /notes/{noteId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && validText()
        && request.resource.data.runId is string
        && (
          !("step" in request.resource.data)
          || request.resource.data.step == null
          || request.resource.data.step is number
        );

      allow update, delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;

        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && validText()
          && request.resource.data.noteId == noteId
          && (
            !("parentId" in request.resource.data)
            || request.resource.data.parentId == null
            || request.resource.data.parentId is string
          );

        allow update, delete: if isAdmin();
      }
    }

    // Legacy collections from the old handle system — curator-only cleanup.
    match /handles/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /meta/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
